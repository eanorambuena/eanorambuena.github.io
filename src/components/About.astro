---
import { es, en } from '../i18n/translations'
---

<section id="about" class="py-28 px-4 relative bg-white/[.02] overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="/about-bg-2.jpeg" alt="" class="w-full h-full object-cover opacity-30" aria-hidden="true" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/60 to-black/80" />
  </div>
  <div class="absolute left-4 md:left-[8%] top-[18%] z-10 hidden md:block">
    <div class="relative flex items-start">
      <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 7v6h6" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="absolute -top-1 left-[30px] text-purple-400 text-sm font-semibold">me</span>
    </div>
  </div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/30 to-transparent z-10" />
  <div class="max-w-3xl mx-auto relative z-10">
    <div data-reveal class="text-center mb-12">
      <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.about.subtitle}</span>
        <span data-lang="en" hidden>{en.about.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.about.title}</span>
        <span data-lang="en" hidden>{en.about.title}</span>
      </h2>
    </div>
    <div data-reveal data-delay="100">
      <div class="bg-zinc-900/60 backdrop-blur-sm border border-white/10 rounded-2xl p-8 md:p-10 space-y-5 text-zinc-300 text-xl leading-relaxed max-w-2xl mx-auto">
        <p data-lang="es" set:html={es.about.p1} />
        <p data-lang="en" hidden set:html={en.about.p1} />
        <p data-lang="es" set:html={es.about.p2} />
        <p data-lang="en" hidden set:html={en.about.p2} />
        <p data-lang="es" set:html={es.about.p3} />
        <p data-lang="en" hidden set:html={en.about.p3} />
      </div>
    </div>
  </div>
</section>
