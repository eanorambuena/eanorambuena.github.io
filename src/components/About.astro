---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
import CVDialog from './CVDialog.jsx'
---

<section id="about" class="py-28 px-4 relative bg-surface-white/[.02] overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="/about-bg-2.jpeg" alt="" class="w-full h-full object-cover opacity-40" aria-hidden="true" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-b from-surface/80 via-surface/60 to-surface/80" />
  </div>
  <div class="absolute left-2 md:left-[12%] top-[14%] z-10 hidden md:block">
    <div class="relative flex items-start">
      <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="-rotate-12">
        <path d="M3 7v6h6" stroke="var(--accent)" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13" stroke="var(--accent)" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="absolute top-1 left-[60px] text-accent text-lg font-['caveat',cursive] font-medium" style="font-family: 'Caveat', cursive;">me</span>
    </div>
  </div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent z-10" />
  <div class="max-w-3xl mx-auto relative z-10">
    <AnimatedSection client:load className="text-center mb-12">
      <p class="text-accent font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.about.subtitle}</span>
        <span data-lang="en" hidden>{en.about.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.about.title}</span>
        <span data-lang="en" hidden>{en.about.title}</span>
      </h2>
    </AnimatedSection>
    <AnimatedSection client:load delay={0.1}>
      <div class="bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 rounded-2xl p-8 md:p-10 space-y-5 text-secondary text-xl leading-relaxed max-w-2xl mx-auto about-text">
        <p data-lang="es" set:html={es.about.p1} />
        <p data-lang="en" hidden set:html={en.about.p1} />
        <p data-lang="es" set:html={es.about.p2} />
        <p data-lang="en" hidden set:html={en.about.p2} />
        <p data-lang="es" set:html={es.about.p3} />
        <p data-lang="en" hidden set:html={en.about.p3} />
        <div class="pt-4 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-border/30 pt-6">
          <span class="text-xs text-muted font-mono tracking-widest uppercase">
            <span data-lang="es">{es.about.educationLabel}</span>
            <span data-lang="en" hidden>{en.about.educationLabel}</span>
          </span>
          <span class="metric text-sm">Computer Engineering</span>
          <span class="text-muted text-sm">·</span>
          <span class="text-secondary text-sm">Pontificia Universidad Católica de Chile</span>
        </div>
        <div class="pt-2 flex gap-3">
          <a
            href="/cv.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-accent text-white text-sm font-medium hover:bg-accent/90 transition-all border-0 group"
          >
            <svg class="w-4 h-4 transition-transform group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span data-lang="es">{es.about.downloadCV}</span>
            <span data-lang="en" hidden>{en.about.downloadCV}</span>
          </a>
          <CVDialog client:load labelEs="¿Qué buscas?" labelEn="What are you looking for?" />
        </div>
      </div>
    </AnimatedSection>
  </div>
</section>
