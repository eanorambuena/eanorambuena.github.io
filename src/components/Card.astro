---
interface Props {
  color?: string
  href?: string
  class?: string
  noHover?: boolean
}

const { color, href, noHover } = Astro.props
const Tag = href ? 'a' : 'div'
const linkProps = href ? { href, target: '_blank', rel: 'noopener noreferrer' } : {}
---

<Tag
  {...linkProps}
  class={`group block relative bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 hover:border-accent/40 rounded-2xl transition-all duration-500 overflow-hidden no-underline h-full flex flex-col ${
    noHover ? '' : 'hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent/10'
  } ${Astro.props.class || ''}`}
>
  {color && (
    <div class={`absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl bg-gradient-to-b ${color} opacity-80 group-hover:opacity-100 transition-opacity`} />
  )}
  <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/0 via-transparent to-accent-secondary/0 group-hover:from-accent/10 group-hover:to-accent-secondary/10 transition-all duration-500 pointer-events-none" />
  <slot />
</Tag>
