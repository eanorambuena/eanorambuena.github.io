---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
import YouTubePlayer from './YouTubePlayer.jsx'
---

<section id="charlas" aria-label={es.charlas.subtitle} class="relative py-24 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="space-y-4 mb-14 text-center">
      <p class="text-accent text-sm font-semibold tracking-widest uppercase">
        <span data-lang="es">{es.charlas.subtitle}</span>
        <span data-lang="en" hidden>{en.charlas.subtitle}</span>
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary">
        <span data-lang="es">{es.charlas.title}</span>
        <span data-lang="en" hidden>{en.charlas.title}</span>
      </h2>
    </AnimatedSection>

    <AnimatedSection client:load className="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="aspect-video relative rounded-2xl overflow-hidden bg-surface-elevated/60 border border-surface/10">
          <YouTubePlayer client:load videoId="mt6ZmbUyLFo" />
        </div>
        <div class="aspect-video relative rounded-2xl overflow-hidden bg-surface-elevated/60 border border-surface/10">
          <YouTubePlayer client:load videoId="n9PxnO6gkg0" />
        </div>
      </div>
      <p class="text-center text-sm text-muted max-w-xl mx-auto">
        <span data-lang="es">{es.charlas.desc}</span>
        <span data-lang="en" hidden>{en.charlas.desc}</span>
      </p>
    </AnimatedSection>
  </div>
</section>
