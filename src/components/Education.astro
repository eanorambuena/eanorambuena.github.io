---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
---

<section id="education" aria-label={es.education.subtitle} class="relative py-16 md:py-20 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="space-y-4 mb-10 text-center">
      <p class="text-accent text-sm font-semibold tracking-widest uppercase">
        <span data-lang="es">{es.education.subtitle}</span>
        <span data-lang="en" hidden>{en.education.subtitle}</span>
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary">
        <span data-lang="es">{es.education.title}</span>
        <span data-lang="en" hidden>{en.education.title}</span>
      </h2>
    </AnimatedSection>

    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      {es.education.items.map((item, i) => (
        <AnimatedSection client:load delay={i * 0.1}>
          <div class="bg-surface-elevated/40 backdrop-blur-sm border border-surface/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
            <div class={`w-12 h-12 rounded-xl shrink-0 flex items-center justify-center bg-gradient-to-br ${i === 0 ? 'from-accent/20 to-accent/10' : 'from-accent-secondary/20 to-accent-secondary/10'}`}>
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-col md:flex-row md:items-center gap-1 md:gap-3 mb-1">
                <span class="font-bold text-primary text-lg block">
                  <span data-lang="es">{item.school}</span>
                  <span data-lang="en" hidden>{en.education.items[i].school}</span>
                </span>
                <span class="text-xs text-muted font-mono whitespace-nowrap">
                  <span data-lang="es">{item.period}</span>
                  <span data-lang="en" hidden>{en.education.items[i].period}</span>
                </span>
              </div>
              <span class="text-sm text-secondary block mb-1">
                <span data-lang="es">{item.degree}</span>
                <span data-lang="en" hidden>{en.education.items[i].degree}</span>
              </span>
              {item.gpa && (
                <span class="text-xs text-muted block">
                  GPA: {item.gpa}
                </span>
              )}
              {item.note && (
                <span class="text-xs text-accent block mt-1 italic">
                  <span data-lang="es">{item.note}</span>
                  <span data-lang="en" hidden>{en.education.items[i].note}</span>
                </span>
              )}
            </div>
          </div>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
