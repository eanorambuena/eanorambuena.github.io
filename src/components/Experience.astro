---
import { es, en } from '../i18n/translations'

const experiences = [
  {
    company: 'NeuralWorks SpA',
    date: '2024 - 2025',
    tags: ['React Native', 'TypeScript', 'Tamagui', 'AI'],
    index: 0,
  },
  {
    company: 'Acofuz',
    date: '2024',
    tags: ['React', 'TypeScript', 'GIS', 'Vite'],
    index: 1,
  },
  {
    company: 'IDS UC',
    date: '2023 - 2024',
    tags: ['Next.js', 'React', 'PostgreSQL', 'AWS'],
    index: 2,
  },
  {
    company: 'Open Source UC',
    date: '2023 - 2024',
    tags: ['Liderazgo', 'Eventos', 'Streaming', 'Comunidad'],
    index: 3,
    url: 'https://osuc.dev/about/',
  },
]
---

<section id="experience" class="py-32 px-4 relative">
  <div class="max-w-2xl mx-auto">
    <div data-reveal class="text-center mb-20">
      <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.experience.subtitle}</span>
        <span data-lang="en" hidden>{en.experience.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.experience.title}</span>
        <span data-lang="en" hidden>{en.experience.title}</span>
      </h2>
      <p class="text-zinc-300 mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.experience.desc}</span>
        <span data-lang="en" hidden>{en.experience.desc}</span>
      </p>
    </div>
    <div class="relative">
      <div class="absolute left-[23px] top-2 bottom-4 w-px bg-gradient-to-b from-purple-500 via-purple-500/30 to-transparent" />
      {experiences.map((exp) => (
        <div data-reveal data-delay={exp.index * 120}>
          <div class="relative pl-12 pb-16 last:pb-0">
            <div class="absolute left-[11px] top-1 w-2.5 h-2.5 rounded-full bg-purple-500 border-2 border-black z-10" />
            <div class="bg-zinc-900/60 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10">
              <div class="flex justify-between items-start mb-2">
                <h3 class="font-bold text-white text-xl">
                  {exp.url ? (
                    <a href={exp.url} target="_blank" rel="noopener noreferrer" class="hover:text-purple-400 transition-colors">{exp.company} ↗</a>
                  ) : exp.company}
                </h3>
                <span class="text-sm text-zinc-300 font-mono">{exp.date}</span>
              </div>
              <p class="text-purple-400 text-lg mb-3 font-medium">
                <span data-lang="es">{es.experience.items[exp.index].role}</span>
                <span data-lang="en" hidden>{en.experience.items[exp.index].role}</span>
              </p>
              <p class="text-zinc-300 text-lg leading-relaxed mb-3">
                <span data-lang="es">{es.experience.items[exp.index].desc}</span>
                <span data-lang="en" hidden>{en.experience.items[exp.index].desc}</span>
              </p>
              <div class="flex flex-wrap gap-2">
                {exp.tags.map((tag) => (
                  <span class="text-sm px-3 py-1 rounded-full bg-black/40 text-zinc-300 border border-white/10">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
