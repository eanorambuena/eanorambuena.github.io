---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
import Badge from './Badge.astro'

const experiences = [
  {
    company: 'NeuralWorks SpA',
    date: '2024 - 2025',
    tags: ['React Native', 'TypeScript', 'Tamagui', 'AI'],
    index: 0,
  },
  {
    company: 'Acofuz',
    date: '2024',
    tags: ['React', 'TypeScript', 'GIS', 'Vite'],
    index: 1,
  },
  {
    company: 'Instituto de Desarrollo Sustentable UC',
    date: '2023 - 2024',
    tags: ['Next.js', 'React', 'PostgreSQL', 'AWS'],
    index: 2,
  },
  {
    company: 'Open Source UC',
    date: '2023 - 2024',
    tags: ['Liderazgo', 'Eventos', 'Streaming', 'Comunidad'],
    index: 3,
    url: 'https://osuc.dev/about/',
  },
]
---

<section id="experience" class="py-32 px-4 relative">
  <div class="max-w-2xl mx-auto">
    <AnimatedSection client:load className="text-center mb-20">
      <p class="text-accent font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.experience.subtitle}</span>
        <span data-lang="en" hidden>{en.experience.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.experience.title}</span>
        <span data-lang="en" hidden>{en.experience.title}</span>
      </h2>
      <p class="text-secondary mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.experience.desc}</span>
        <span data-lang="en" hidden>{en.experience.desc}</span>
      </p>
    </AnimatedSection>
    <div class="relative">
      <div class="absolute left-6 top-2 bottom-4 w-px bg-gradient-to-b from-accent via-accent/30 to-transparent" />
      {experiences.map((exp) => (
        <AnimatedSection client:load delay={exp.index * 0.12}>
          <div class="relative pl-14 pb-20 last:pb-0">
            <div class="absolute left-6 top-1 w-3 h-3 rounded-full bg-accent border-[3px] border-surface -translate-x-1/2 z-10 shadow-lg shadow-accent/30 animate-pulse" />
            <div class="group relative bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 hover:border-accent/30 rounded-2xl p-6 transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent/10 overflow-hidden">
              <div class={`absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl bg-gradient-to-b from-accent via-accent-secondary to-accent opacity-80 group-hover:opacity-100 transition-opacity`} />
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/0 via-transparent to-accent-secondary/0 group-hover:from-accent/10 group-hover:to-accent-secondary/10 transition-all duration-500 pointer-events-none" />
              <div class="relative">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="font-bold text-primary text-xl">
                    {exp.url ? (
                      <a href={exp.url} target="_blank" rel="noopener noreferrer" class="text-primary hover:text-accent transition-colors">{exp.company} ↗</a>
                    ) : exp.company}
                  </h3>
                  <span class="text-sm text-muted font-mono whitespace-nowrap ml-4">{exp.date}</span>
                </div>
                <p class="text-accent text-base mb-3 font-semibold tracking-wide">
                  <span data-lang="es">{es.experience.items[exp.index].role}</span>
                  <span data-lang="en" hidden>{en.experience.items[exp.index].role}</span>
                </p>
                <p class="text-secondary leading-relaxed mb-4">
                  <span data-lang="es">{es.experience.items[exp.index].desc}</span>
                  <span data-lang="en" hidden>{en.experience.items[exp.index].desc}</span>
                </p>
                <div class="flex flex-wrap gap-2">
                  {exp.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
