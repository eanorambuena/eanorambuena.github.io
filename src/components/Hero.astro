---
import Hero3D from './Hero3D.jsx'
import HeroContent from './HeroContent.jsx'
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-surface via-surface to-accent/20 z-0" />
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-12 items-center min-h-screen py-20">
      <HeroContent client:load />
      <div class="hidden md:flex items-center justify-center h-full">
        <Hero3D client:load />
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <button onclick="document.getElementById('about')?.scrollIntoView({ behavior: 'smooth' })" class="text-secondary hover:text-accent transition-colors bg-transparent border-none p-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </button>
  </div>
</section>
