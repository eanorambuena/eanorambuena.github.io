---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'

const repos = [
  {
    name: 'emmy-dom',
    descEs: 'Librería de componentes web funcionales en TypeScript con patrón Elm. Renderizado declarativo, reactividad sin Virtual DOM.',
    descEn: 'Functional web components library in TypeScript with Elm-inspired patterns. Declarative rendering, reactivity without Virtual DOM.',
    lang: 'TypeScript',
    stars: '45',
    downloads: '1,000+',
    npm: 'emmy-dom',
    url: 'https://github.com/emmyjs/emmy-dom',
    color: 'from-purple-500 to-blue-500',
  },
  {
    name: 'Kalmate',
    descEs: 'Terminal financiera estilo Bloomberg con datos Yahoo Finance en tiempo real. Nuxt 3, TradingView charts, sin API keys.',
    descEn: 'Bloomberg-style financial terminal with real-time Yahoo Finance data. Nuxt 3, TradingView charts, no API keys needed.',
    lang: 'Vue',
    stars: '8',
    downloads: null,
    npm: null,
    url: 'https://github.com/eanorambuena/kalmate',
    color: 'from-blue-500 to-cyan-500',
  },
]
---

<section id="opensource" class="py-28 px-4 relative bg-surface-white/[.02]">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="text-center mb-16">
      <p class="text-accent font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.opensource.subtitle}</span>
        <span data-lang="en" hidden>{en.opensource.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.opensource.title}</span>
        <span data-lang="en" hidden>{en.opensource.title}</span>
      </h2>
      <p class="text-secondary mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.opensource.desc}</span>
        <span data-lang="en" hidden>{en.opensource.desc}</span>
      </p>
    </AnimatedSection>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
      {repos.map((repo, i) => (
        <AnimatedSection client:load delay={i * 0.1}>
          <a
            href={repo.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block relative bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 hover:border-accent/40 rounded-2xl p-6 transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent/10 overflow-hidden h-full"
          >
            <div class={`absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl bg-gradient-to-b ${repo.color} opacity-80 group-hover:opacity-100 transition-opacity`} />
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/0 via-transparent to-accent-secondary/0 group-hover:from-accent/10 group-hover:to-accent-secondary/10 transition-all duration-500 pointer-events-none" />
            <div class="relative">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center group-hover:bg-accent/30 transition-colors">
                  <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                </div>
                <h3 class="text-lg font-bold text-primary group-hover:text-accent transition-colors">{repo.name}</h3>
              </div>
              <p class="text-secondary text-sm leading-relaxed mb-5">
                <span data-lang="es">{repo.descEs}</span>
                <span data-lang="en" hidden>{repo.descEn}</span>
              </p>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted">
                <span class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-accent-secondary" />
                  {repo.lang}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
                  {repo.stars}
                </span>
                {repo.downloads && (
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                    {repo.downloads}
                  </span>
                )}
              </div>
              <div class="mt-4 text-sm text-accent opacity-0 group-hover:opacity-100 transition-opacity font-medium">
                <span data-lang="es">{es.opensourceGH}</span>
                <span data-lang="en" hidden>{en.opensourceGH}</span>
              </div>
            </div>
          </a>
        </AnimatedSection>
      ))}
    </div>

    <AnimatedSection client:load className="space-y-6 mb-12">
      <div class="aspect-video max-w-2xl mx-auto rounded-2xl overflow-hidden bg-surface-elevated/60 border border-surface/10">
        <iframe id="yt-video" width="100%" height="100%" src="https://www.youtube.com/embed/WSNAkqKNt94?start=585" title="FUNCTIONAL WEB COMPONENTS | EL FUTURO DE LA WEB" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen class="w-full h-full"></iframe>
      </div>
      <p class="text-center text-sm text-muted">
        <span data-lang="es">Functional Web Components — Charla sobre emmy-dom en el meetup de Open Source UC</span>
        <span data-lang="en" hidden>Functional Web Components — Talk about emmy-dom at Open Source UC meetup</span>
      </p>
    </AnimatedSection>

    <div class="text-center">
      <a
        href="https://github.com/eanorambuena"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-secondary hover:text-accent transition-colors font-medium group"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        <span data-lang="es">{es.opensource.viewAll}</span>
        <span data-lang="en" hidden>{en.opensource.viewAll}</span>
      </a>
    </div>
  </div>
</section>
