---
import { es, en } from '../i18n/translations'
---

<section id="opensource" class="py-28 px-4 relative bg-white/[.02]">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.opensource.subtitle}</span>
        <span data-lang="en" hidden>{en.opensource.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.opensource.title}</span>
        <span data-lang="en" hidden>{en.opensource.title}</span>
      </h2>
      <p class="text-zinc-300 mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.opensource.desc}</span>
        <span data-lang="en" hidden>{en.opensource.desc}</span>
      </p>
    </div>
    <div class="space-y-6 mb-12">
      <div class="aspect-video max-w-2xl mx-auto rounded-2xl overflow-hidden bg-zinc-900/60 border border-white/10">
        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/WSNAkqKNt94?autoplay=1&mute=1" title="FUNCTIONAL WEB COMPONENTS | EL FUTURO DE LA WEB" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen class="w-full h-full"></iframe>
      </div>
    </div>
    <div class="max-w-lg mx-auto">
      <a
        href="https://github.com/emmyjs/emmy-dom"
        target="_blank"
        rel="noopener noreferrer"
        class="group block bg-zinc-900/60 backdrop-blur-sm border border-purple-500/20 hover:border-purple-500/40 rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10"
      >
        <div class="w-16 h-16 rounded-2xl bg-purple-500/20 flex items-center justify-center mx-auto mb-5 group-hover:bg-purple-500/30 transition-colors">
          <svg class="w-8 h-8 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">emmy-dom</h3>
        <p class="text-zinc-300 text-sm mb-4 max-w-sm mx-auto leading-relaxed">
  <span data-lang="es">Librería de componentes web funcionales en TypeScript con patrón Elm para el DOM. 1,000+ descargas en npm.</span>
  <span data-lang="en" hidden>Functional web components library in TypeScript with Elm-inspired patterns for the DOM. 1,000+ npm downloads.</span>
</p>
        <div class="flex items-center justify-center gap-4 text-sm text-zinc-300">
          <span class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-blue-500" />
            TypeScript
          </span>
          <span class="text-purple-400/60">|</span>
          <span>
            <span data-lang="es">1,000+ descargas totales en npm</span>
            <span data-lang="en" hidden>1,000+ total npm downloads</span>
          </span>
        </div>
        <div class="mt-4 text-sm text-purple-400 opacity-0 group-hover:opacity-100 transition-opacity">
          <span data-lang="es">{es.opensourceGH}</span>
          <span data-lang="en" hidden>{en.opensourceGH}</span>
        </div>
      </a>
    </div>
    <div class="text-center mt-10">
      <a
        href="https://github.com/eanorambuena"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-300 hover:text-purple-400 transition-colors font-medium"
      >
        <span data-lang="es">{es.opensource.viewAll}</span>
        <span data-lang="en" hidden>{en.opensource.viewAll}</span>
      </a>
    </div>
  </div>
</section>
