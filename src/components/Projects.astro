---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'

const projects = [
  {
    titleEs: 'NeuralWorks — Gestión de Clientes',
    titleEn: 'NeuralWorks — Client Management',
    descKey: 'neural',
    image: '/projects/neural.png',
    tags: ['React', 'TypeScript', 'User Management', 'Dashboard'],
    links: [],
    color: 'from-emerald-500 to-teal-500',
  },
  {
    titleEs: 'App GIS para Minería',
    titleEn: 'GIS App for Mining',
    descKey: 'gis',
    image: '/projects/emmyjs.png',
    tags: ['React', 'TypeScript', 'GIS', 'Vite'],
    links: [{ labelEs: 'Web →', labelEn: 'Web →', url: 'https://procel.acofuz.com' }],
    color: 'from-orange-500 to-red-500',
  },
  {
    titleEs: 'Loopaas',
    titleEn: 'Loopaas',
    descKey: 'peer',
    tags: ['Next.js', 'React', 'PostgreSQL', 'AWS'],
    links: [],
    color: 'from-green-500 to-teal-500',
  },
  {
    titleEs: 'Kalmate',
    titleEn: 'Kalmate',
    descKey: 'kalmate',
    tags: ['Nuxt 3', 'Vue', 'TypeScript', 'Yahoo Finance'],
    links: [{ labelEs: 'Demo →', labelEn: 'Live Demo →', url: 'https://kalmate.app' }],
    color: 'from-blue-500 to-cyan-500',
  },
]

const descEN = {
  kalmate: 'Bloomberg-style financial terminal with real-time market data via Yahoo Finance API, built with Nuxt 3 and TradingView charts.',
  peer: 'Peer evaluation platform serving 1,500+ concurrent students with real-time dashboards. Cut grading time by 60% across 3+ universities.',
  gis: 'Frontend GIS visualization app built for Acofuz, used by Procel and Antofagasta Minerals. Handles 50k+ geospatial data points with interactive maps and data layers.',
  neural: 'Client management and user administration dashboard built for NeuralWorks. Role-based access, real-time updates, and comprehensive client lifecycle management.',
}

const descES = {
  kalmate: 'Terminal financiera estilo Bloomberg con datos de mercado en tiempo real vía Yahoo Finance API, construido con Nuxt 3 y TradingView charts.',
  peer: 'Plataforma de coevaluaciones para 1,500+ estudiantes concurrentes con dashboards en tiempo real. Redujo tiempo de corrección en 60% en 3+ universidades.',
  gis: 'App de visualización GIS construida para Acofuz, usada por Procel y Antofagasta Minerals. Maneja 50k+ puntos de datos geoespaciales con mapas interactivos.',
  neural: 'Dashboard de gestión de clientes y administración de usuarios construido para NeuralWorks. Acceso basado en roles, actualizaciones en tiempo real.',
}
---

<section id="projects" class="py-36 px-4 relative bg-white/[.02]">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="text-center mb-20">
      <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.projects.subtitle}</span>
        <span data-lang="en" hidden>{en.projects.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.projects.title}</span>
        <span data-lang="en" hidden>{en.projects.title}</span>
      </h2>
      <p class="text-zinc-300 mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.projects.desc}</span>
        <span data-lang="en" hidden>{en.projects.desc}</span>
      </p>
    </AnimatedSection>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p, i) => (
          <AnimatedSection client:load delay={i * 0.1}>
            <div class="group relative bg-zinc-900/60 backdrop-blur-sm border border-white/10 hover:border-purple-500/40 rounded-2xl transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-purple-500/10 overflow-hidden">
              {p.image && (
                <div class="relative h-44 overflow-hidden">
                  <img src={p.image} alt={p.titleEs} class="w-full h-full object-cover object-top" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-zinc-900/40 to-transparent" />
                </div>
              )}
              <div class={`absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl bg-gradient-to-b ${p.color} opacity-80 group-hover:opacity-100 transition-opacity`} />
            <div class="p-6">
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-purple-500/0 via-transparent to-blue-500/0 group-hover:from-purple-500/10 group-hover:to-blue-500/10 transition-all duration-500 pointer-events-none" />
              <h3 class="text-2xl font-bold text-white mb-2 relative">
                <span data-lang="es">{p.titleEs}</span>
                <span data-lang="en" hidden>{p.titleEn}</span>
              </h3>
              <p class="text-zinc-300 text-lg mb-4 leading-relaxed relative">
                <span data-lang="es">{descES[p.descKey]}</span>
                <span data-lang="en" hidden>{descEN[p.descKey]}</span>
              </p>
              <div class="flex flex-wrap gap-2 mb-4 relative">
                {p.tags.map((tag) => (
                  <span class="text-sm px-3 py-1.5 rounded-full bg-purple-900/30 text-purple-300 border border-purple-500/20">{tag}</span>
                ))}
              </div>
              <div class="flex flex-wrap gap-3 relative">
                {p.links.map((l) => (
                  <a href={l.url} target="_blank" rel="noopener noreferrer" class="text-sm text-purple-400 hover:text-purple-300 transition-colors font-medium">
                    <span data-lang="es">{l.labelEs}</span>
                    <span data-lang="en" hidden>{l.labelEn}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
