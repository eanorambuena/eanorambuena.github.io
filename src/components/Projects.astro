---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
import Card from './Card.astro'
import Badge from './Badge.astro'

const projects = [
  {
    titleEs: 'NeuralWorks — Práctica Fullstack',
    titleEn: 'NeuralWorks — Fullstack Internship',
    slug: 'neuralworks',
    descKey: 'neural',
    image: '/projects/neural-app.png',
    tags: ['React Native', 'TypeScript', 'AWS', 'Tamagui'],
    links: [],
    color: 'from-emerald-500 to-teal-500',
  },
  {
    titleEs: 'Smartlokus: GIS para Minería',
    titleEn: 'Smartlokus: GIS App for Mining',
    slug: 'smartlokus',
    descKey: 'gis',
    image: '/projects/emmyjs.png',
    tags: ['React', 'TypeScript', 'GIS', 'Vite'],
    links: [{ labelEs: 'Web →', labelEn: 'Web →', url: 'https://procel.acofuz.com/login' }],
    color: 'from-orange-500 to-red-500',
  },
  {
    titleEs: 'Loopaas: Coevaluaciones Universitarias',
    titleEn: 'Loopaas: Peer Evaluation Platform',
    slug: 'loopaas',
    descKey: 'peer',
    tags: ['Next.js', 'React', 'PostgreSQL', 'Supabase', 'Auth0'],
    links: [],
    iframe: 'https://idsapp.vercel.app/',
    color: 'from-green-500 to-teal-500',
  },
  {
    titleEs: 'Kalmate: Terminal Financiera',
    titleEn: 'Kalmate: Financial Terminal',
    slug: 'kalmate',
    descKey: 'kalmate',
    tags: ['Nuxt 3', 'Vue', 'TypeScript', 'Yahoo Finance'],
    links: [{ labelEs: 'Demo →', labelEn: 'Live Demo →', url: 'https://kalmate.pages.dev' }],
    iframe: 'https://kalmate.pages.dev',
    color: 'from-blue-500 to-cyan-500',
  },
]

const descEN = {
  kalmate: 'Bloomberg-style financial terminal with real-time market data via Yahoo Finance API, built with Nuxt 3 and TradingView charts.',
  peer: 'Peer evaluation platform with QR attendance, SSO, anonymous peer reviews, and grade reports. Replaced Google Forms + GScript that saturated PCs with 16GB RAM.',
  gis: 'GIS app for mining built for Acofuz. Frontend scaffolded from scratch with extensible architecture. Python backend integration via API.',
  neural: 'Fullstack intern en NeuralWorks. Migré UI a Tamagui, construí módulo de inventario POS, optimicé infraestructura AWS/Docker y reduje costos de IA de >$200/mes a $0 con Cursor Rules.',
}

const descES = {
  kalmate: 'Terminal financiera estilo Bloomberg con datos de mercado en tiempo real vía Yahoo Finance API, construido con Nuxt 3 y TradingView charts.',
  peer: 'Plataforma de coevaluaciones con asistencia QR, SSO, evaluaciones anónimas entre pares e informes de notas. Reemplazó Google Forms + GScript que saturaba PCs con 16GB RAM.',
  gis: 'App GIS para minería construida para Acofuz. Frontend desde cero con arquitectura extensible. Integración vía API con backend Python.',
  neural: 'Fullstack intern en NeuralWorks. Migré UI a Tamagui, construí módulo de inventario POS, optimicé infraestructura AWS/Docker y reduje costos de IA de >$200/mes a $0 con Cursor Rules.',
}
---

<section id="projects" class="py-36 px-4 relative bg-surface-white/[.02]">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="text-center mb-20">
      <p class="text-accent font-mono text-sm tracking-widest uppercase mb-4">
        <span data-lang="es">{es.projects.subtitle}</span>
        <span data-lang="en" hidden>{en.projects.subtitle}</span>
      </p>
      <h2 class="text-4xl md:text-5xl font-bold gradient-text">
        <span data-lang="es">{es.projects.title}</span>
        <span data-lang="en" hidden>{en.projects.title}</span>
      </h2>
      <p class="text-secondary mt-4 max-w-md mx-auto">
        <span data-lang="es">{es.projects.desc}</span>
        <span data-lang="en" hidden>{en.projects.desc}</span>
      </p>
    </AnimatedSection>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 auto-rows-fr">
      {projects.map((p, i) => (
          <AnimatedSection client:load delay={i * 0.1}>
            <Card href={`/projects/${p.slug}`} color={p.color}>
              {p.iframe ? (
                <div class="relative h-44 overflow-hidden bg-surface" transition:name={`${p.slug}-media`}>
                  <div class="w-[250%] h-[250%] origin-top-left scale-[0.4]">
                    <iframe src={p.iframe} title={p.titleEs} class="w-full h-full border-0" loading="lazy" style="pointer-events: none;" />
                  </div>
                  <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/60 to-transparent" />
                </div>
              ) : p.image && (
                <div class="relative h-44 overflow-hidden" transition:name={`${p.slug}-media`}>
                  <img src={p.image} alt={p.titleEs} class="w-full h-full object-cover object-top" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/40 to-transparent" />
                </div>
              )}
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-2xl font-bold text-primary mb-2 relative" transition:name={`${p.slug}-title`}>
                <span data-lang="es">{p.titleEs}</span>
                <span data-lang="en" hidden>{p.titleEn}</span>
              </h3>
              <p class="text-secondary text-lg mb-4 leading-relaxed relative">
                <span data-lang="es">{descES[p.descKey]}</span>
                <span data-lang="en" hidden>{descEN[p.descKey]}</span>
              </p>
              <div class="flex flex-wrap gap-2 flex-1 items-end">
                {p.tags.map((tag) => (
                  <Badge>{tag}</Badge>
                ))}
              </div>
            </div>
          </Card>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
