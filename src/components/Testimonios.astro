---
import { es, en } from '../i18n/translations'
import AnimatedSection from './AnimatedSection.jsx'
---

<section id="testimonios" aria-label={es.testimonios.subtitle} class="relative py-24 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <AnimatedSection client:load className="space-y-4 mb-14 text-center">
      <p class="text-accent text-sm font-semibold tracking-widest uppercase">
        <span data-lang="es">{es.testimonios.subtitle}</span>
        <span data-lang="en" hidden>{en.testimonios.subtitle}</span>
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary">
        <span data-lang="es">{es.testimonios.title}</span>
        <span data-lang="en" hidden>{en.testimonios.title}</span>
      </h2>
    </AnimatedSection>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {es.testimonios.items.map((item, i) => (
        <AnimatedSection client:load delay={i * 0.1}>
          <blockquote class="h-full bg-surface-elevated/40 backdrop-blur-sm border border-surface/10 rounded-2xl p-6 md:p-8 flex flex-col">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
              <span class="h-px flex-1 bg-surface/10" />
            </div>
            <p class="text-secondary text-sm md:text-base leading-relaxed flex-1 italic">
              <span data-lang="es">"{item.text}"</span>
              <span data-lang="en" hidden>"{en.testimonios.items[i].text}"</span>
            </p>
            <footer class="mt-6 pt-4 border-t border-surface/10">
              <span class="font-semibold text-primary text-sm block" data-lang="es">{item.name}</span>
              <span class="font-semibold text-primary text-sm block" data-lang="en" hidden>{en.testimonios.items[i].name}</span>
              <span class="text-muted text-xs block mt-0.5" data-lang="es">{item.role}</span>
              <span class="text-muted text-xs block mt-0.5" data-lang="en" hidden>{en.testimonios.items[i].role}</span>
            </footer>
          </blockquote>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
