---
import { es, en } from '../i18n/translations'
import { logos } from '../data/logos'
import ThemeImage from './ThemeImage.astro'

const companies = Object.entries(logos).map(([name, entry]) => ({ name, ...entry }))
const isFiltered = (entry) => entry.filterDark || entry.filterLight
---

<section class="py-28 overflow-hidden">
  <div class="text-center mb-12">
    <p class="text-accent font-mono text-sm tracking-widest uppercase mb-3">
      <span data-lang="es">{es.trustedBy.subtitle}</span>
      <span data-lang="en" hidden>{en.trustedBy.subtitle}</span>
    </p>
    <h2 class="text-3xl md:text-4xl font-bold gradient-text">
      <span data-lang="es">{es.trustedBy.title}</span>
      <span data-lang="en" hidden>{en.trustedBy.title}</span>
    </h2>
  </div>

  <div class="relative w-full overflow-hidden">
    <div class="flex" id="marquee-track">
      {[...companies, ...companies].map((c, i) => (
        <div
          key={i}
          class={`flex-shrink-0 w-48 h-28 ${i < companies.length * 2 - 1 ? 'mr-8' : ''} bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 rounded-2xl flex items-center justify-center px-4 hover:border-accent/30 hover:bg-surface-elevated/80 transition-all duration-300 relative overflow-hidden`}
        >
          <div class="absolute top-0 left-4 right-4 h-0.5 bg-gradient-to-r from-accent/40 to-accent-secondary/40 rounded-full" />
          {
            c.inline ? (
              <>
                <div class={`w-full h-full flex items-center justify-center ${c.inlineClass || 'p-5'} dark-only`} set:html={c.dark} />
                <div class={`w-full h-full flex items-center justify-center ${c.inlineClass || 'p-5'} light-only`} set:html={c.light} />
              </>
            ) : isFiltered(c) ? (
              <img
                src={c.dark}
                alt={`${c.name} logo`}
                class={`${c.imgClass || 'max-h-[85%] max-w-[85%]'} object-contain theme-filter`}
                loading="lazy"
              />
            ) : c.dark !== c.light ? (
              <>
                <img
                  src={c.dark}
                  alt={`${c.name} logo`}
                  class={`${c.imgClass || 'max-h-[85%] max-w-[85%]'} object-contain dark-only`}
                  loading="lazy"
                />
                <img
                  src={c.light}
                  alt={`${c.name} logo`}
                  class={`${c.imgClass || 'max-h-[85%] max-w-[85%]'} object-contain light-only`}
                  loading="lazy"
                />
              </>
            ) : (
              <img
                src={c.dark}
                alt={`${c.name} logo`}
                class={`${c.imgClass || 'max-h-[85%] max-w-[85%]'} object-contain`}
                loading="lazy"
              />
            )
          }
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #marquee-track {
    width: max-content;
    will-change: transform;
  }
  .dark-only { display: block; opacity: 1; transition: opacity 0.4s ease; }
  .light-only { display: none; opacity: 0; transition: opacity 0.4s ease; }
  :global(.light) .dark-only { display: none; opacity: 0; }
  :global(.light) .light-only { display: block; opacity: 1; }
  .theme-filter {
    filter: brightness(0) invert(1);
    transition: filter 0.4s ease;
  }
  :global(.light) .theme-filter {
    filter: brightness(0);
  }
</style>

<script>
  const track = document.getElementById('marquee-track')
  if (track) {
    let pos = 0
    let speed = 1.2
    const half = track.scrollWidth / 2

    function step() {
      pos -= speed
      if (pos <= -half) pos = 0
      track.style.transform = `translateX(${pos}px)`
      requestAnimationFrame(step)
    }
    requestAnimationFrame(step)

    track.addEventListener('mouseenter', () => { speed = 0 })
    track.addEventListener('mouseleave', () => { speed = 1.2 })
  }
</script>
