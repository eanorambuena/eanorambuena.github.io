---
import { es, en } from '../i18n/translations'

const osucSvg = `<svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
  <path d="M449.318 284.209C449.318 375.396 375.396 449.318 284.209 449.318L284.209 284.209L449.318 284.209Z" fill="white"/>
  <path d="M449.318 50.6824V215.791C358.131 215.791 284.209 141.869 284.209 50.6824L449.318 50.6824Z" fill="white"/>
  <path d="M215.791 50.6824L215.791 215.791L50.6824 215.791C50.6824 124.604 124.604 50.6824 215.791 50.6824Z" fill="white"/>
  <path d="M50.6824 284.209C141.869 284.209 215.791 358.131 215.791 449.318H50.6824L50.6824 284.209Z" fill="white"/>
  <path d="M274.211 225.831V274.169H225.79V225.831H274.211Z" fill="white"/>
  <path d="M191.657 284.21C205.005 284.21 215.868 295.03 215.868 308.379C215.868 321.727 205.005 332.547 191.657 332.547C178.309 332.547 167.447 321.727 167.447 308.379C167.447 295.03 178.309 284.21 191.657 284.21Z" fill="white"/>
  <path d="M308.419 167.446C321.768 167.446 332.63 178.267 332.63 191.615C332.63 204.963 321.768 215.784 308.419 215.784C295.071 215.784 284.209 204.963 284.209 191.615C284.209 178.267 295.071 167.446 308.419 167.446Z" fill="white"/>
</svg>`

const companies = [
  { name: 'Antofagasta Minerals', logo: 'https://expandemineria.cl/wp-content/uploads/2024/05/AMSA-Logo-300x94.png' },
  { name: 'Procel', logo: 'https://www.procelservicios.cl/img/logo.png' },
  { name: 'Acofuz', logo: '/acofuz-logo.png' },
  { name: 'NeuralWorks', logo: '/nw-logo.svg' },
  { name: 'Universidad Católica', logo: 'https://upload.wikimedia.org/wikipedia/commons/d/d8/Marca-uc.svg' },
  { name: 'OSUC', logo: osucSvg, inline: true },
  { name: 'Esert', logo: '/esert-logo.png' },
  { name: 'EME SG', logo: '/emesg-logo.png' },
  { name: 'Aguas Andinas', logo: '/aguas-andinas-logo.png' },
]
---

<section class="py-28 overflow-hidden">
  <div class="text-center mb-12">
    <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-3">
      <span data-lang="es">{es.trustedBy.subtitle}</span>
      <span data-lang="en" hidden>{en.trustedBy.subtitle}</span>
    </p>
    <h2 class="text-3xl md:text-4xl font-bold gradient-text">
      <span data-lang="es">{es.trustedBy.title}</span>
      <span data-lang="en" hidden>{en.trustedBy.title}</span>
    </h2>
  </div>

  <div class="relative w-full overflow-hidden">
    <div class="flex gap-8" id="marquee-track">
      {[...companies, ...companies].map((c, i) => (
        <div
          key={i}
          class="flex-shrink-0 w-48 h-28 bg-zinc-900/60 backdrop-blur-sm border border-white/10 rounded-2xl flex items-center justify-center px-4 hover:border-purple-500/30 hover:bg-zinc-900/80 transition-all duration-300 relative overflow-hidden"
        >
          <div class="absolute top-0 left-4 right-4 h-0.5 bg-gradient-to-r from-purple-500/40 to-blue-500/40 rounded-full" />
          {
            c.inline ? (
              <div class="text-white w-full h-full flex items-center justify-center p-5" set:html={c.logo} />
            ) : (
              <img
                src={c.logo}
                alt={`${c.name} logo`}
                class="max-h-[85%] max-w-[90%] object-contain"
                loading="lazy"
              />
            )
          }
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  #marquee-track {
    animation: marquee 35s linear infinite;
    width: max-content;
    will-change: transform;
  }
  #marquee-track:hover {
    animation-play-state: paused;
  }
</style>
