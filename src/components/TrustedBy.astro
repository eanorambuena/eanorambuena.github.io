---
import { es, en } from '../i18n/translations'

const companies = [
  { subtitle: 'Minería', logo: 'https://www.logo.wine/a/logo/Antofagasta_PLC/Antofagasta_PLC-Logo.wine.svg' },
  { subtitle: 'Fintech', logo: 'https://www.procelservicios.cl/img/logo.png' },
  { subtitle: 'Construcción', logo: 'https://www.acofuz.com/static/highways/img/apple-touch-icon.png' },
  { subtitle: 'IA / ML', logo: 'https://www.neuralworks.cl/NW-logo-white.svg' },
  { subtitle: 'Educación', logo: 'https://upload.wikimedia.org/wikipedia/commons/d/d8/Marca-uc.svg' },
]
---

<section class="py-28 overflow-hidden">
  <div class="text-center mb-12">
    <p class="text-purple-400 font-mono text-sm tracking-widest uppercase mb-3">
      <span data-lang="es">{es.trustedBy.subtitle}</span>
      <span data-lang="en" hidden>{en.trustedBy.subtitle}</span>
    </p>
    <h2 class="text-3xl md:text-4xl font-bold gradient-text">
      <span data-lang="es">{es.trustedBy.title}</span>
      <span data-lang="en" hidden>{en.trustedBy.title}</span>
    </h2>
  </div>

  <div class="relative w-full overflow-hidden">
    <div class="flex gap-8" id="marquee-track">
      {[...companies, ...companies].map((c, i) => (
        <div
          key={i}
          class="flex-shrink-0 w-48 h-28 bg-zinc-900/60 backdrop-blur-sm border border-white/10 rounded-2xl flex flex-col items-center justify-center px-3 hover:border-purple-500/30 hover:bg-zinc-900/80 transition-all duration-300 relative overflow-hidden"
        >
          <div class="absolute top-0 left-4 right-4 h-0.5 bg-gradient-to-r from-purple-500/40 to-blue-500/40 rounded-full" />
          <div class="flex items-center justify-center h-14 mb-1">
            <img
              src={c.logo}
              alt={`${c.subtitle} logo`}
              class="max-h-full max-w-[120px] object-contain"
              loading="lazy"
            />
          </div>
          <span class="text-xs text-zinc-400 font-mono">{c.subtitle}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  #marquee-track {
    animation: marquee 35s linear infinite;
    width: max-content;
    will-change: transform;
  }
  #marquee-track:hover {
    animation-play-state: paused;
  }
</style>
