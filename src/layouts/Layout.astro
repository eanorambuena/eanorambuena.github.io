---
import Navbar from '../components/Navbar.jsx'
import { es, en } from '../i18n/translations'
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Emmanuel Norambuena — Product Engineer & Builder</title>
    <meta name="description" content="Emmanuel Norambuena — Product Engineer. AI infrastructure, full-stack development, and real-time systems. Based in Chile." />
    <meta name="author" content="Emmanuel Norambuena" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href="https://eanorambuena.github.io" />
    <link rel="alternate" hreflang="es" href="https://eanorambuena.github.io" />
    <link rel="alternate" hreflang="en" href="https://eanorambuena.github.io" />
    <link rel="alternate" hreflang="x-default" href="https://eanorambuena.github.io" />
    <script>
      (function() {
        var lang = localStorage.getItem('portfolio-lang') || 'es'
        document.documentElement.lang = lang
        window.addEventListener('langchange', function() {
          document.documentElement.lang = localStorage.getItem('portfolio-lang') || 'es'
        })
      })()
    </script>
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://eanorambuena.github.io" />
    <meta property="og:title" content="Emmanuel Norambuena — Product Engineer & Builder" />
    <meta property="og:description" content="Emmanuel Norambuena — Product Engineer. AI infrastructure, full-stack development, and real-time systems. Based in Chile." />
    <meta property="og:image" content="https://eanorambuena.github.io/og-image.png" />
    <meta property="og:site_name" content="Emmanuel Norambuena" />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@eanorambuena" />
    <meta name="twitter:title" content="Emmanuel Norambuena — Product Engineer & Builder" />
    <meta name="twitter:description" content="Emmanuel Norambuena — Product Engineer. AI infrastructure, full-stack development, and real-time systems. Based in Chile." />
    <meta name="twitter:image" content="https://eanorambuena.github.io/og-image.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Emmanuel Norambuena",
      "url": "https://eanorambuena.github.io",
      "jobTitle": "Product Engineer",
      "email": "eanorambuena@uc.cl",
      "sameAs": ["https://github.com/eanorambuena", "https://linkedin.com/in/eanorambuena"]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <style>
      @import "tailwindcss";
      *:focus-visible {
        outline: 2px solid #a855f7;
        outline-offset: 2px;
        border-radius: 8px;
      }
      [data-reveal] {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      }
      [data-reveal].visible {
        opacity: 1;
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
      body {
        animation: fadeIn 0.3s ease-out;
      }
      @keyframes fadeIn {
        from { opacity: 0 }
        to { opacity: 1 }
      }
    </style>
  </head>
  <body class="bg-black text-white antialiased min-h-screen overflow-x-hidden font-['Inter',sans-serif]">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-purple-600 focus:text-white focus:rounded-lg focus:outline-none">
      Skip to main content
    </a>
    <div class="fixed inset-0 pointer-events-none z-[1]" style="background-image: radial-gradient(rgba(168,85,247,0.06) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="fixed inset-0 pointer-events-none z-[1]" style="background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(168,85,247,0.06), transparent), radial-gradient(ellipse 60% 40% at 80% 100%, rgba(59,130,246,0.05), transparent);"></div>
    <Navbar client:load />
    <slot />
    <footer class="relative z-10 text-center text-zinc-300 text-sm py-12 border-t border-white/10">
      <div class="max-w-md mx-auto space-y-2">
        <p>Emmanuel Norambuena</p>
        <a href="mailto:eanorambuena@uc.cl" class="text-zinc-300 hover:text-purple-400 transition-colors inline-block py-2">eanorambuena@uc.cl</a>
        <p class="text-xs text-zinc-300">
          <span data-lang="es">{es.footer.built}</span>
          <span data-lang="en" hidden>{en.footer.built}</span>
        </p>
      </div>
    </footer>
    <script>
    (function(){
      var easter = [
        '\n  %c  🥚  You found the easter egg!',
        '%c  ─────────────────────────────',
        '%c  Hi there, fellow dev 👋',
        '%c  Built with Astro + React + Three.js',
        '%c  https://github.com/eanorambuena/eanorambuena.github.io',
        '%c  ─────────────────────────────',
        '%c  "Building products people love"\n',
        'font-size: 24px',
        'font-size: 12px; color: #6b7280',
        'font-size: 14px; color: #e5e7eb',
        'font-size: 12px; color: #a855f7',
        'font-size: 12px; color: #3b82f6; text-decoration: underline',
        'font-size: 12px; color: #6b7280',
        'font-size: 14px; color: #e5e7eb; font-style: italic',
      ]
      console.log(easter[0], ...easter.slice(7))
      console.log(easter[1], easter[7])
      console.log(easter.slice(2, 7).join('\n'), ...easter.slice(7))
    })();
    </script>
    <script>
    (function(){
      function applyLang(lang) {
        document.querySelectorAll('[data-lang]').forEach(function(el) {
          el.hidden = el.getAttribute('data-lang') !== lang
        })
      }
      var lang = localStorage.getItem('portfolio-lang') || 'es'
      applyLang(lang)
      window.addEventListener('langchange', function() {
        applyLang(localStorage.getItem('portfolio-lang') || 'es')
      })
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var delay = entry.target.getAttribute('data-delay') || 0
              setTimeout(function() {
                entry.target.classList.add('visible')
              }, parseInt(delay, 10))
              observer.unobserve(entry.target)
            }
          })
        }, { rootMargin: '0px 0px -60px 0px' })
        document.querySelectorAll('[data-reveal]').forEach(function(el) {
          observer.observe(el)
        })
      } else {
        document.querySelectorAll('[data-reveal]').forEach(function(el) {
          el.classList.add('visible')
        })
      }
    })();
    </script>
  </body>
</html>
