---
import Navbar from '../components/Navbar.jsx'
import { es, en } from '../i18n/translations'
import 'flag-icons/css/flag-icons.min.css'
import ClientRouter from 'astro/components/ClientRouter.astro'
const site = Astro.site
const siteUrl = site?.origin || 'https://eanorambuena.github.io'
const ogImage = `${siteUrl}/og-image.svg`
const ogImagePng = `${siteUrl}/og-image.png`
const ogImageW = 1200
const ogImageH = 630
const dateModified = new Date().toISOString().split('T')[0]
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Emmanuel Norambuena — Product Engineer & Builder</title>
    <meta name="description" content="Emmanuel Norambuena es un Product Engineer chileno especializado en AI infrastructure, full-stack development y real-time systems. Reduje costos de IA de $200/usuario a $0 y construí plataformas para 1,500+ usuarios." />
    <meta name="author" content="Emmanuel Norambuena" />
    <meta name="keywords" content="eanorambuena, Emmanuel Norambuena, Product Engineer Chile, AI infrastructure, full-stack developer Chile, React developer, Three.js, NeuralWorks, Pontificia Universidad Católica de Chile, startup Chile, desarrollo web Chile" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="revisit-after" content="7 days" />
    <meta name="theme-color" id="theme-color-meta" content="#0a0a0a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/og-image.svg" />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en`} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <link rel="me" href="https://github.com/eanorambuena" />
    <link rel="me" href="https://linkedin.com/in/eanorambuena" />
    <link rel="me" href="https://x.com/eanorambuena" />
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://avatars.githubusercontent.com" />
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://avatars.githubusercontent.com" />

    <script>
      (function() {
        var theme = localStorage.getItem('portfolio-theme')
        if (theme !== 'dark' && theme !== 'light') {
          theme = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
        }
        document.documentElement.setAttribute('data-theme', theme)
        var meta = document.querySelector('meta[name="theme-color"]')
        if (meta) meta.content = theme === 'light' ? '#fafafa' : '#0a0a0a'
      })()
    </script>
    <script>
      (function() {
        var lang = localStorage.getItem('portfolio-lang') || 'es'
        document.documentElement.lang = lang
        window.addEventListener('langchange', function() {
          document.documentElement.lang = localStorage.getItem('portfolio-lang') || 'es'
        })
      })()
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content="Emmanuel Norambuena — Product Engineer & Builder" />
    <meta property="og:description" content="Product Engineer chileno. AI infrastructure, full-stack development, real-time systems. Reduje costos de IA de $200/u a $0. Construí plataformas para 1,500+ usuarios concurrentes." />
    <meta property="og:image" content={ogImagePng} />
    <meta property="og:image:width" content={String(ogImageW)} />
    <meta property="og:image:height" content={String(ogImageH)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Emmanuel Norambuena — Product Engineer & Builder" />
    <meta property="og:image:secure_url" content={ogImagePng} />
    <meta property="og:site_name" content="Emmanuel Norambuena" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:country-name" content="Chile" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@eanorambuena" />
    <meta name="twitter:site" content="@eanorambuena" />
    <meta name="twitter:title" content="Emmanuel Norambuena — Product Engineer & Builder" />
    <meta name="twitter:description" content="Product Engineer chileno. AI infrastructure, full-stack, real-time systems." />
    <meta name="twitter:image" content={ogImagePng} />

    <meta property="al:web:url" content={siteUrl} />
    <meta property="al:web:should_fallback" content="true" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": siteUrl,
      "name": "Emmanuel Norambuena",
      "alternateName": "Emmanuel Norambuena — Product Engineer & Builder",
      "inLanguage": ["es-CL", "en-US"],
      "description": "Portfolio personal de Emmanuel Norambuena, Product Engineer chileno. AI infrastructure, full-stack development, y real-time systems.",
      "image": ogImagePng,
      "author": {
        "@type": "Person",
        "@id": siteUrl + "#person"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": siteUrl + "/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": siteUrl + "#person",
      "name": "Emmanuel Norambuena",
      "givenName": "Emmanuel",
      "familyName": "Norambuena",
      "url": siteUrl,
      "jobTitle": "Product Engineer",
      "email": "eanorambuena@uc.cl",
      "image": `${siteUrl}/eanorambuena.jpg`,
      "nationality": {
        "@type": "Country",
        "name": "Chile"
      },
      "birthPlace": {
        "@type": "Country",
        "name": "Chile"
      },
      "homeLocation": {
        "@type": "Place",
        "name": "Chile",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "CL"
        }
      },
      "knowsAbout": [
        "Software Engineering",
        "React",
        "TypeScript",
        "Artificial Intelligence",
        "AI Infrastructure",
        "Product Development",
        "Web Development",
        "Full Stack Development",
        "Three.js",
        "Node.js",
        "AWS",
        "PostgreSQL",
        "React Native"
      ],
      "knowsLanguage": ["Spanish", "English"],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Pontificia Universidad Católica de Chile",
        "url": "https://www.uc.cl"
      },
      "worksFor": {
        "@type": "Organization",
        "name": "NeuralWorks SpA",
        "url": "https://neuralworks.cl"
      },
      "sameAs": [
        "https://github.com/eanorambuena",
        "https://linkedin.com/in/eanorambuena",
        "https://x.com/eanorambuena",
        "https://linktr.ee/eanorambuena"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "url": siteUrl + "/",
      "name": "Emmanuel Norambuena — Product Engineer & Builder",
      "description": "Portfolio de Emmanuel Norambuena, Product Engineer. AI infrastructure, full-stack development, real-time systems.",
      "image": [ogImagePng, `${siteUrl}/eanorambuena.jpg`],
      "mainEntity": {
        "@id": siteUrl + "#person"
      },
      "dateCreated": "2024-01-01",
      "dateModified": dateModified,
      "datePublished": "2024-01-01"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        }
      ]
    })} />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <style>
      @import "tailwindcss";

      @theme {
        --color-surface: var(--surface);
        --color-surface-elevated: var(--surface-elevated);
        --color-surface-white: var(--surface-white);
        --color-primary: var(--primary);
        --color-secondary: var(--secondary);
        --color-muted: var(--muted);
        --color-accent: var(--accent);
        --color-accent-secondary: var(--accent-secondary);
        --color-border: var(--border);
      }

      [data-theme="dark"] {
        --surface: #0a0a0a;
        --surface-elevated: #18181b;
        --surface-white: #ffffff;
        --primary: #fafafa;
        --secondary: #d4d4d8;
        --muted: #808089;
        --accent: #ab5cf7;
        --accent-secondary: #3b82f6;
        --border: rgba(255, 255, 255, 0.1);
        --logo-filter: brightness(0) invert(1);
      }

      :root,
      [data-theme="light"] {
        --surface: #fafafa;
        --surface-elevated: #f4f4f5;
        --surface-white: #000000;
        --primary: #09090b;
        --secondary: #3f3f46;
        --muted: #6b6b73;
        --accent: #7c3aed;
        --accent-secondary: #2563eb;
        --border: rgba(0, 0, 0, 0.1);
        --logo-filter: brightness(0);
      }

      .gradient-text {
        color: var(--accent);
        background: linear-gradient(to right, var(--accent), var(--accent-secondary));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .metric {
        color: var(--accent);
        font-weight: 700;
        font-size: 1.1em;
      }
      .hero-metric {
        color: var(--accent);
        font-weight: 700;
      }
      .about-text strong {
        color: var(--accent);
        font-weight: 700;
      }
      @media (max-width: 768px) {
        .metric, .about-text strong {
          font-size: 1em;
        }
      }

      *:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 8px;
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
      body {
        animation: fadeIn 0.3s ease-out;
        transition: background-color 0.5s ease, color 0.5s ease, border-color 0.5s ease;
      }
      nav, section, footer {
        transition: background-color 0.5s ease, border-color 0.5s ease;
      }
      .reduce-motion, .reduce-motion * {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
      .high-contrast {
        --primary: #000000;
        --secondary: #1a1a1a;
        --muted: #333333;
        --border: rgba(0, 0, 0, 0.3);
      }
      [data-theme="dark"].high-contrast {
        --primary: #ffffff;
        --secondary: #e0e0e0;
        --muted: #b0b0b0;
        --border: rgba(255, 255, 255, 0.3);
      }
      @keyframes fadeIn {
        from { opacity: 0 }
        to { opacity: 1 }
      }
    </style>
  </head>
  <body class="bg-surface text-primary antialiased min-h-screen overflow-x-hidden font-['Inter',sans-serif]">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg focus:outline-none">
      Skip to main content
    </a>
    <div class="fixed inset-0 pointer-events-none z-[1]" style="background-image: radial-gradient(color-mix(in srgb, var(--accent) 6%, transparent) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="fixed inset-0 pointer-events-none z-[1]" style="background: radial-gradient(ellipse 80% 50% at 50% -10%, color-mix(in srgb, var(--accent) 6%, transparent), transparent), radial-gradient(ellipse 60% 40% at 80% 100%, color-mix(in srgb, var(--accent-secondary) 5%, transparent), transparent);"></div>
    <Navbar client:load />
    <slot />
    <footer class="relative z-10 border-t border-border">
      <div class="max-w-5xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div class="space-y-3">
            <p class="text-primary font-semibold">Emmanuel Norambuena</p>
            <p class="text-sm text-muted">Product Engineer basado en Chile.</p>
            <a href="mailto:eanorambuena@uc.cl" class="text-sm text-muted hover:text-accent transition-colors inline-block">eanorambuena@uc.cl</a>
          </div>
          <div class="space-y-3">
            <p class="text-muted text-xs font-semibold uppercase tracking-wider">Links</p>
            <div class="flex flex-col gap-1.5">
              <a href="https://github.com/eanorambuena" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-accent transition-colors">GitHub</a>
              <a href="https://linkedin.com/in/eanorambuena" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-accent transition-colors">LinkedIn</a>
              <a href="https://x.com/eanorambuena" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-accent transition-colors">X / Twitter</a>
              <a href="https://linktr.ee/eanorambuena" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-accent transition-colors">Linktree</a>
              <a href="/buy-me-a-coffee" class="text-sm text-[#00c853] hover:text-[#00e060] transition-colors">Donar</a>
            </div>
          </div>
          <div class="space-y-3">
            <p class="text-muted text-xs font-semibold uppercase tracking-wider">Stack</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 rounded-md bg-surface-elevated text-muted">Astro</span>
              <span class="text-xs px-2 py-1 rounded-md bg-surface-elevated text-muted">React</span>
              <span class="text-xs px-2 py-1 rounded-md bg-surface-elevated text-muted">Three.js</span>
              <span class="text-xs px-2 py-1 rounded-md bg-surface-elevated text-muted">Tailwind</span>
            </div>
          </div>
        </div>
        <div class="border-t border-surface/50 pt-6 text-center">
          <p class="text-xs text-muted">
            <span data-lang="es">{es.footer.built}</span>
            <span data-lang="en" hidden>{en.footer.built}</span>
          </p>
        </div>
      </div>
    </footer>
    <script>
    (function(){
      var easter = [
        '\n  %c  🥚  You found the easter egg!',
        '%c  ─────────────────────────────',
        '%c  Hi there, fellow dev 👋',
        '%c  Built with Astro + React + Three.js',
        '%c  https://github.com/eanorambuena/eanorambuena.github.io',
        '%c  ─────────────────────────────',
        '%c  "Building products people love"\n',
        'font-size: 24px',
        'font-size: 12px; color: #6b7280',
        'font-size: 14px; color: #e5e7eb',
        'font-size: 12px; color: #a855f7',
        'font-size: 12px; color: #3b82f6; text-decoration: underline',
        'font-size: 12px; color: #6b7280',
        'font-size: 14px; color: #e5e7eb; font-style: italic',
      ]
      console.log(easter[0], ...easter.slice(7))
      console.log(easter[1], easter[7])
      console.log(easter.slice(2, 7).join('\n'), ...easter.slice(7))
    })();
    </script>
    <script>
    (function(){
      function applyLang(lang) {
        document.querySelectorAll('[data-lang]').forEach(function(el) {
          el.hidden = el.getAttribute('data-lang') !== lang
        })
      }
      var lang = localStorage.getItem('portfolio-lang') || 'es'
      applyLang(lang)
      window.addEventListener('langchange', function() {
        applyLang(localStorage.getItem('portfolio-lang') || 'es')
      })

    })();
    </script>
  </body>
</html>
