---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Página no encontrada | Emmanuel Norambuena" description="Página no encontrada. El portfolio de Emmanuel Norambuena incluye proyectos, noticias y más. Usa la navegación para encontrar lo que buscas." ogImage="/og-image.png">
  <main id="main-content" class="relative z-10 min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div class="text-8xl md:text-9xl font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl md:text-3xl font-semibold text-primary mb-4" data-lang="es">Página no encontrada</h1>
      <h1 class="text-2xl md:text-3xl font-semibold text-primary mb-4" data-lang="en" hidden>Page not found</h1>
      <p class="text-secondary text-lg mb-8" data-lang="es">La página que buscas no existe o fue movida.</p>
      <p class="text-secondary text-lg mb-8" data-lang="en" hidden>The page you are looking for does not exist or has been moved.</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent/15 text-primary font-medium hover:bg-accent/25 transition-all border border-accent/10 no-underline"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span data-lang="es">Volver al inicio</span>
        <span data-lang="en" hidden>Back to home</span>
      </a>
    </div>
  </main>
</Layout>
