---
import Layout from '../layouts/Layout.astro'
import { donateEs, donateEn } from '../i18n/translations'
---

<Layout title="Donar | Emmanuel Norambuena" description="Apoya el trabajo de Emmanuel Norambuena como Product Engineer. Donaciones en Bitcoin vía Buda.">
  <main id="main-content" class="relative z-10 min-h-screen flex items-center justify-center px-6 py-24">
    <div class="max-w-lg w-full text-center">
      <div class="mb-2 text-accent text-sm font-mono tracking-widest uppercase" data-lang="es">{donateEs.subtitle}</div>
      <div class="mb-2 text-accent text-sm font-mono tracking-widest uppercase" data-lang="en" hidden>{donateEn.subtitle}</div>

      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4" data-lang="es">{donateEs.title}</h1>
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4" data-lang="en" hidden>{donateEn.title}</h1>

      <p class="text-secondary text-lg leading-relaxed mb-8" data-lang="es">{donateEs.desc}</p>
      <p class="text-secondary text-lg leading-relaxed mb-8" data-lang="en" hidden>{donateEn.desc}</p>

      <div class="bg-surface-elevated border border-border rounded-2xl p-8 mb-6">
        <div class="w-16 h-16 rounded-full bg-[#00c853]/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-[#00c853]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-primary font-bold text-xl mb-2" data-lang="es">{donateEs.buda}</p>
        <p class="text-primary font-bold text-xl mb-2" data-lang="en" hidden>{donateEn.buda}</p>
        <p class="text-muted text-sm mb-6" data-lang="es">{donateEs.budaDesc}</p>
        <p class="text-muted text-sm mb-6" data-lang="en" hidden>{donateEn.budaDesc}</p>
        <a
          href="https://www.buda.com/link/eanorambuena"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#00c853] text-black font-bold px-8 py-4 rounded-xl text-lg hover:bg-[#00e060] transition-all no-underline"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          ₿ Buda
        </a>
      </div>

      <a href="/" class="inline-flex items-center gap-1 text-muted hover:text-accent transition-colors text-sm no-underline">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span data-lang="es">Volver al inicio</span>
        <span data-lang="en" hidden>Back to home</span>
      </a>
    </div>
  </main>
</Layout>

<style is:global>
  [data-theme="dark"] .bg-surface-elevated {
    background-color: #18181b;
  }
  [data-theme="light"] .bg-surface-elevated {
    background-color: #f4f4f5;
  }
</style>
