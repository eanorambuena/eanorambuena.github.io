---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Education from '../components/Education.astro';
import TrustedBy from '../components/TrustedBy.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import OpenSource from '../components/OpenSource.astro';
import Charlas from '../components/Charlas.astro';
import Testimonios from '../components/Testimonios.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "VideoObject",
        "name": "Functional Web Components con emmy-dom — Open Source UC",
        "description": "Charla sobre Functional Web Components con emmy-dom en Open Source UC.",
        "thumbnailUrl": "https://img.youtube.com/vi/mt6ZmbUyLFo/maxresdefault.jpg",
        "uploadDate": "2024-01-01",
        "embedUrl": "https://www.youtube.com/embed/mt6ZmbUyLFo",
        "contentUrl": "https://www.youtube.com/watch?v=mt6ZmbUyLFo"
      },
      {
        "@type": "VideoObject",
        "name": "emmy-dom: Functional Web Components Library",
        "description": "Presentación de la librería emmy-dom de Functional Web Components.",
        "thumbnailUrl": "https://img.youtube.com/vi/n9PxnO6gkg0/maxresdefault.jpg",
        "uploadDate": "2024-01-01",
        "embedUrl": "https://www.youtube.com/embed/n9PxnO6gkg0",
        "contentUrl": "https://www.youtube.com/watch?v=n9PxnO6gkg0"
      }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Featured Projects",
    "description": "Real products shipped for real users — from open source to fintech to mining.",
    "numberOfItems": 4,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "url": "https://eanorambuena.github.io/projects/neuralworks/",
        "name": "NeuralWorks — Fullstack POS"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "url": "https://eanorambuena.github.io/projects/smartlokus/",
        "name": "Smartlokus: GIS App for Mining"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "url": "https://eanorambuena.github.io/projects/loopaas/",
        "name": "Loopaas: Peer Evaluation Platform"
      },
      {
        "@type": "ListItem",
        "position": 4,
        "url": "https://eanorambuena.github.io/projects/kalmate/",
        "name": "Kalmate: Financial Terminal"
      }
    ]
  })} />
  <main id="main-content" class="relative z-10">
    <Hero />
    <About />
    <Education />
    <TrustedBy />
    <Experience />
    <div class="relative h-24 -mt-1 overflow-hidden">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="absolute inset-0 w-full h-full">
        <path d="M0,30 C360,80 1080,0 1440,40 L1440,100 L0,100 Z" fill="rgba(168,85,247,0.02)" />
      </svg>
    </div>
    <Projects />
    <OpenSource />
    <Charlas />
    <section class="py-16 px-4 relative">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-accent font-mono text-sm tracking-widest uppercase mb-4">
          <span data-lang="es">Prensa</span>
          <span data-lang="en" hidden>Press</span>
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4" data-lang="es">Apariciones en prensa</h2>
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4" data-lang="en" hidden>Press mentions</h2>
        <p class="text-secondary max-w-lg mx-auto mb-8" data-lang="es">Noticias, entrevistas y menciones en medios y organizaciones.</p>
        <p class="text-secondary max-w-lg mx-auto mb-8" data-lang="en" hidden>News, interviews, and mentions across media and organizations.</p>
        <a
          href="/news"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent/15 text-primary font-medium hover:bg-accent/25 transition-all border border-accent/10 no-underline group"
        >
          <span data-lang="es">Ver todas las apariciones</span>
          <span data-lang="en" hidden>View all mentions</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>
    <Testimonios />
    <Skills />
    <Contact />
  </main>
</Layout>
