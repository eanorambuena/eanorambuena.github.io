---
import Layout from '../layouts/Layout.astro'

const kindColor = {
  'Prensa': 'from-blue-500 to-cyan-500',
  'Press': 'from-blue-500 to-cyan-500',
  'Aparición': 'from-purple-500 to-pink-500',
  'Feature': 'from-purple-500 to-pink-500',
  'Documento': 'from-amber-500 to-orange-500',
  'Document': 'from-amber-500 to-orange-500',
}

const newsItems = [
  {
    kindEs: 'Prensa',
    kindEn: 'Press',
    date: '2020-03-30',
    source: 'Matemáticas UC',
    url: 'https://www.mat.uc.cl/noticias/2020-03-30/taller-de-investigacion-matematica-inicio-sus-clases-en-linea.html',
    titleEs: 'Taller de investigación matemática inició sus clases en línea',
    titleEn: 'Mathematical Research Workshop Started Its Classes Online',
    summaryEs: 'Nota de Matemáticas UC sobre el inicio en modalidad online del taller de investigación matemática.',
    summaryEn: 'Mathematics UC article about the start of the mathematical research workshop in online format.',
  },
  {
    kindEs: 'Aparición',
    kindEn: 'Feature',
    date: '',
    source: 'Open Source UC',
    url: 'https://osuc.dev/about/',
    titleEs: 'About de Open Source UC',
    titleEn: 'Open Source UC About Page',
    summaryEs: 'Página de la comunidad Open Source UC donde aparezco como parte del equipo y trayectoria de la organización.',
    summaryEn: 'Open Source UC community page where I appear as part of the team and organization history.',
  },
  {
    kindEs: 'Aparición',
    kindEn: 'Feature',
    date: '',
    source: 'Instagram',
    url: 'https://www.instagram.com/reel/CzB-wLVuWg8/',
    titleEs: 'Reel en Instagram',
    titleEn: 'Instagram Reel',
    summaryEs: 'Publicación en formato reel donde también aparezco.',
    summaryEn: 'Reel-format post where I also appear.',
  },
  {
    kindEs: 'Prensa',
    kindEn: 'Press',
    date: '',
    source: 'Ingeniería UC',
    url: 'https://www.ing.uc.cl/noticias/novatos-y-novatas-reciben-reconocimiento-en-ceremonia-de-matricula-de-honor/',
    titleEs: 'Novatos y novatas reciben reconocimiento en ceremonia de Matrícula de Honor',
    titleEn: 'Freshmen Receive Recognition at the Honors Enrollment Ceremony',
    summaryEs: 'Nota de Ingeniería UC sobre la ceremonia de Matrícula de Honor, donde también aparezco.',
    summaryEn: 'Engineering UC article about the Honors Enrollment Ceremony, where I also appear.',
  },
  {
    kindEs: 'Documento',
    kindEn: 'Document',
    date: '2018',
    source: 'Olimpiada de Matemática de Chile',
    url: '/news/FinalONM2018.pdf',
    titleEs: 'Final ONM 2018 (PDF)',
    titleEn: 'ONM 2018 Final (PDF)',
    summaryEs: 'Documento oficial en PDF de la Olimpiada Nacional de Matemática 2018, donde aparezco mencionado.',
    summaryEn: 'Official PDF document for the 2018 National Math Olympiad final, where I am mentioned.',
  },
]
---

<Layout>
  <main id="main-content" class="relative z-10 min-h-screen px-6 pt-28 pb-20">
    <section class="max-w-5xl mx-auto">
      <p class="text-accent text-sm font-mono tracking-widest uppercase mb-3" data-lang="es">Prensa</p>
      <p class="text-accent text-sm font-mono tracking-widest uppercase mb-3" data-lang="en" hidden>Newsroom</p>

      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-5" data-lang="es">Noticias, prensa y apariciones</h1>
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-5" data-lang="en" hidden>News, Press, and Features</h1>

      <p class="text-secondary text-lg leading-relaxed max-w-3xl" data-lang="es">
        Esta sección reúne apariciones en prensa, noticias y menciones donde participo o soy citado.
      </p>
      <p class="text-secondary text-lg leading-relaxed max-w-3xl" data-lang="en" hidden>
        This section gathers press mentions, news, and pages where I am featured or referenced.
      </p>
    </section>

    <section class="max-w-5xl mx-auto mt-10 space-y-6">
      {newsItems.map((item) => {
        const color = kindColor[item.kindEs] || 'from-gray-500 to-gray-600'
        const isInstagram = item.url.includes('instagram.com')
        const isPdf = item.url.endsWith('.pdf')
        return (
          <article class="group relative bg-surface-elevated/60 backdrop-blur-sm border border-surface/10 hover:border-accent/40 rounded-2xl transition-all duration-500 overflow-hidden hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent/10">
            <div class={`absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b ${color} z-10 opacity-80 group-hover:opacity-100 transition-opacity`} />
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/0 via-transparent to-accent-secondary/0 group-hover:from-accent/[0.04] group-hover:to-accent-secondary/[0.04] transition-all duration-500 pointer-events-none" />

            {isInstagram ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="block relative w-full no-underline" style="aspect-ratio: 16/9;">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500 via-pink-500 to-yellow-500 opacity-40 group-hover:opacity-60 transition-opacity" />
                <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/30 to-transparent" />
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-3">
                  <svg class="w-12 h-12 text-white/80" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                  <span class="text-white/70 text-xs font-mono tracking-wider">instagram.com</span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="inline-flex items-center gap-2 text-white/90 text-sm font-medium">
                    <span data-lang="es">Ver en Instagram</span>
                    <span data-lang="en" hidden>View on Instagram</span>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </span>
                </div>
              </a>
            ) : isPdf ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="block relative w-full no-underline" style="aspect-ratio: 16/9;">
                <div class="absolute inset-0 bg-gradient-to-br from-red-500 via-rose-500 to-orange-500 opacity-30 group-hover:opacity-50 transition-opacity" />
                <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/30 to-transparent" />
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-3">
                  <svg class="w-12 h-12 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                  <span class="text-white/70 text-xs font-mono tracking-wider">PDF</span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="inline-flex items-center gap-2 text-white/90 text-sm font-medium">
                    <span data-lang="es">Ver PDF</span>
                    <span data-lang="en" hidden>View PDF</span>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </span>
                </div>
              </a>
            ) : (
            <div class="relative w-full" style="aspect-ratio: 21/9;">
              <iframe
                src={item.url}
                title={item.titleEs}
                class="w-full h-full border-0"
                loading="lazy"
                sandbox="allow-scripts"
                allow="geolocation 'none'"
                style="pointer-events: none;"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/30 to-transparent pointer-events-none" />
            </div>
            )}

            <div class="p-5 md:p-6">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-accent/15 text-primary border border-accent/10" data-lang="es">
                  {item.kindEs}
                </span>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-accent/15 text-primary border border-accent/10" data-lang="en" hidden>
                  {item.kindEn}
                </span>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-surface/50 text-secondary border border-border/30">
                  {item.source}
                </span>
                {item.date ? (
                  <time class="text-xs text-muted font-mono tracking-wide" datetime={item.date}>{item.date}</time>
                ) : (
                  <>
                    <span class="text-xs text-muted font-mono tracking-wide" data-lang="es">Fecha no indicada</span>
                    <span class="text-xs text-muted font-mono tracking-wide" data-lang="en" hidden>Date not specified</span>
                  </>
                )}
              </div>

              <h2 class="text-xl md:text-2xl font-bold text-primary leading-snug mb-2" data-lang="es">{item.titleEs}</h2>
              <h2 class="text-xl md:text-2xl font-bold text-primary leading-snug mb-2" data-lang="en" hidden>{item.titleEn}</h2>

              <p class="text-secondary text-sm leading-relaxed mb-3" data-lang="es">{item.summaryEs}</p>
              <p class="text-secondary text-sm leading-relaxed mb-3" data-lang="en" hidden>{item.summaryEn}</p>

              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-accent hover:text-accent-secondary transition-colors no-underline font-medium text-sm"
              >
                <span data-lang="es">Ver noticia</span>
                <span data-lang="en" hidden>Read article</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 3h7m0 0v7m0-7L10 14" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5h6M5 5v14h14v-6" />
                </svg>
              </a>
            </div>
          </article>
        )
      })}
    </section>
  </main>
</Layout>
