---
import Layout from '../../layouts/Layout.astro'
import AnimatedSection from '../../components/AnimatedSection.jsx'
import { es, en } from '../../i18n/translations'

export async function getStaticPaths() {
  const slugs = ['neuralworks', 'smartlokus', 'loopaas', 'kalmate']
  return slugs.map((slug) => ({ params: { slug } }))
}

const { slug } = Astro.params

const projects: Record<string, any> = {
  neuralworks: {
    titleEs: 'NeuralWorks — Práctica Fullstack',
    titleEn: 'NeuralWorks — Fullstack Internship',
    tags: ['React Native', 'TypeScript', 'AWS', 'Tamagui', 'Docker', 'Expo'],
    image: '/projects/neural-app.png',
    costImage: '/projects/neural-costs.png',
    color: 'from-emerald-500 to-teal-500',
    featuresEs: [
      'Migración UI de React Native Paper a Tamagui con Design Tokens',
      'Módulo Fullstack de control y edición de inventario (POS)',
      'Infraestructura cloud con AWS, SST, Pulumi, Hono y Drizzle ORM',
      'Reducción de Swap de memoria de 7.28GB a 5.9GB con Docker',
      'Implementación de Cursor Rules: costos IA de >$200/mes a $0',
      'Transición a Atomic PRs para eliminar merge conflicts',
      'Componentes reutilizables, Custom Hooks y Zustand stores',
      'Sistema de puntos, historial de compras y filtrado por email',
    ],
    featuresEn: [
      'UI migration from React Native Paper to Tamagui with Design Tokens',
      'Fullstack inventory control and editing module (POS)',
      'Cloud infrastructure with AWS, SST, Pulumi, Hono, and Drizzle ORM',
      'Memory Swap reduction from 7.28GB to 5.9GB with Docker',
      'Cursor Rules implementation: AI costs from >$200/mo to $0',
      'Atomic PRs transition to eliminate merge conflicts',
      'Reusable components, Custom Hooks, and Zustand stores',
      'Points system, purchase history, and email filtering',
    ],
    longDescEs: 'Durante mi Práctica Profesional II en NeuralWorks trabajé como Fullstack Software Engineer Intern en el proyecto interno HOP, un Point of Sale (POS) para Tablets. Lideré la migración de la UI legacy de React Native Paper a Tamagui, diseñé e implementé el módulo completo de inventario (cliente + servidor), y optimicé la infraestructura cloud con AWS, SST y Docker. También implementé Cursor Rules que redujeron los costos de IA de >$200/mes a $0, y establecí flujos de Atomic PRs para eliminar cuellos de botella en el equipo.',
    longDescEn: 'During my Professional Internship II at NeuralWorks I worked as a Fullstack Software Engineer Intern on the internal HOP project, a Point of Sale (POS) for Tablets. I led the UI migration from legacy React Native Paper to Tamagui, designed and implemented the complete inventory module (client + server), and optimized cloud infrastructure with AWS, SST, and Docker. I also implemented Cursor Rules that reduced AI costs from >$200/mo to $0, and established Atomic PR workflows to eliminate team bottlenecks.',
  },
  smartlokus: {
    titleEs: 'Smartlokus: GIS para Minería',
    titleEn: 'Smartlokus: GIS App for Mining',
    tags: ['React', 'TypeScript', 'GIS', 'Vite'],
    image: '/projects/emmyjs.png',
    color: 'from-orange-500 to-red-500',
    testimonialEs: '"Trabajar en el frontend de Smartlokus fue muy fácil gracias a lo extensible y ordenado del código base." — Compañero de equipo',
    testimonialEn: '"Working on the Smartlokus frontend was very easy thanks to how extensible and clean the codebase was." — Team member',
    featuresEs: [
      'Frontend scaffolded desde cero, escalable y mantenible',
      'Integración vía API con backend Python',
      'Comunicación constante con equipo backend para integraciones',
      'Visualización de datos geoespaciales con mapas interactivos',
      'Arquitectura extensible para nuevas funcionalidades',
    ],
    featuresEn: [
      'Frontend scaffolded from scratch, scalable and maintainable',
      'API integration with Python backend',
      'Constant collaboration with backend team',
      'Geospatial data visualization with interactive maps',
      'Extensible architecture for future features',
    ],
    longDescEs: 'Aplicación GIS de visualización de datos geoespaciales construida para Acofuz, utilizada por Procel y Antofagasta Minerals. Frontend desarrollado desde cero con React, TypeScript y Vite, con arquitectura escalable y mantenible. Integración vía API con backend Python para procesamiento de datos geoespaciales.',
    longDescEn: 'GIS visualization app built for Acofuz, used by Procel and Antofagasta Minerals. Frontend built from scratch with React, TypeScript, and Vite, with scalable and maintainable architecture. API integration with Python backend for geospatial data processing.',
  },
  loopaas: {
    titleEs: 'Loopaas: Coevaluaciones Universitarias',
    titleEn: 'Loopaas: Peer Evaluation Platform',
    tags: ['Next.js', 'React', 'PostgreSQL', 'Supabase', 'Auth0'],
    iframe: 'https://idsapp.vercel.app/',
    color: 'from-green-500 to-teal-500',
    featuresEs: [
      'Evaluaciones peer-to-peer anónimas',
      'Crear, editar y eliminar criterios y sus porcentajes',
      'Control de asistencia por escaneo QR',
      'SSO con Supabase y Auth0',
      'Generación de informes de notas descargables',
      'SEO optimizado',
      'Dashboard en tiempo real para profesores',
      'Reemplazo de Google Forms + GScript que saturaba PCs con 16 GB RAM',
    ],
    featuresEn: [
      'Anonymous peer-to-peer evaluations',
      'Create, edit, and delete criteria with custom percentages',
      'QR code attendance tracking',
      'SSO with Supabase and Auth0',
      'Grade report generation',
      'SEO optimized',
      'Real-time dashboard for professors',
      'Replaced Google Forms + GScript that saturated PCs with 16 GB RAM',
    ],
    longDescEs: 'Plataforma de coevaluaciones universitarias. Los estudiantes se evalúan entre sí de forma anónima con criterios personalizables. Incluye control de asistencia por QR, SSO con Supabase y Auth0, informes de notas descargables y SEO optimizado. Originalmente era un Google Form cuyo procesamiento con GScript saturaba cualquier PC, incluso con 16 GB de RAM. Construido con Next.js, React, PostgreSQL, Supabase y Auth0.',
    longDescEn: 'Peer evaluation platform. Students evaluate each other anonymously with customizable criteria. Includes QR attendance tracking, SSO with Supabase and Auth0, downloadable grade reports, and SEO optimization. Originally a Google Form whose GScript processing saturated any PC, even with 16 GB of RAM. Built with Next.js, React, PostgreSQL, Supabase, and Auth0.',
  },
  kalmate: {
    titleEs: 'Kalmate: Terminal Financiera',
    titleEn: 'Kalmate: Financial Terminal',
    tags: ['Nuxt 3', 'Vue', 'TypeScript', 'Yahoo Finance', 'TradingView'],
    iframe: 'https://kalmate.pages.dev',
    color: 'from-blue-500 to-cyan-500',
    featuresEs: [
      'Datos de mercado en tiempo real vía Yahoo Finance API',
      'Dashboard categorizado: Equities, Forex, Bonds, Commodities, Crypto',
      'Portafolio con seguimiento de P&L',
      'Alertas inteligentes con notificaciones del navegador',
      'Screener con filtros, presets y ordenamiento',
      'Noticias financieras integradas',
      'Cacheo inteligente del servidor (30s quotes, 5min history)',
      'Atajos de teclado para navegación eficiente',
    ],
    featuresEn: [
      'Real-time market data via Yahoo Finance API',
      'Categorized dashboard: Equities, Forex, Bonds, Commodities, Crypto',
      'Portfolio with P&L tracking',
      'Smart alerts with browser notifications',
      'Screener with filters, presets, and sorting',
      'Integrated financial news',
      'Intelligent server caching (30s quotes, 5min history)',
      'Keyboard shortcuts for efficient navigation',
    ],
    longDescEs: 'Terminal financiera estilo Bloomberg con datos de mercado en tiempo real vía Yahoo Finance API. Construido con Nuxt 3, Vue 3, TypeScript y TradingView charts. Dashboard categorizado (Equities, Forex, Bonds, Commodities, Crypto), portafolio con P&L, alertas inteligentes con notificaciones del navegador, screener con filtros y presets, y noticias financieras. Cacheo inteligente del servidor y atajos de teclado para navegación eficiente. Sin necesidad de API keys.',
    longDescEn: 'Bloomberg-style financial terminal with real-time market data via Yahoo Finance API. Built with Nuxt 3, Vue 3, TypeScript, and TradingView charts. Categorized dashboard (Equities, Forex, Bonds, Commodities, Crypto), portfolio with P&L tracking, smart alerts with browser notifications, screener with filters and presets, and financial news. Intelligent server caching and keyboard shortcuts for efficient navigation. No API keys required.',
  },
}

const project = projects[slug as keyof typeof projects]

if (!project) {
  return Astro.redirect('/404')
}
---

<Layout>
  <main id="main-content" class="relative z-10 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 py-24 md:py-32">
      <AnimatedSection client:load className="mb-12">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-sm text-muted hover:text-accent transition-colors font-mono mb-12 group"
        >
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          <span data-lang="es">Volver a proyectos</span>
          <span data-lang="en" hidden>Back to projects</span>
        </a>
      </AnimatedSection>

      <AnimatedSection client:load delay={0.1}>
        <div class="relative bg-surface-elevated/60 backdrop-blur-sm border border-border rounded-2xl overflow-hidden mb-12">
          <div class={`absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b ${project.color}`} />
          {project.iframe ? (
            <div class="relative w-full" style="aspect-ratio: 16/10;" transition:name={`${slug}-media`}>
              <iframe
                src={project.iframe}
                title={project.titleEs}
                class="w-full h-full border-0"
                loading="lazy"
                style="pointer-events: none;"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/20 to-transparent pointer-events-none" />
            </div>
          ) : (
            <div class="relative w-full" style="aspect-ratio: 16/10;" transition:name={`${slug}-media`}>
              <img
                src={project.image}
                alt={project.titleEs}
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-elevated via-surface-elevated/20 to-transparent pointer-events-none" />
            </div>
          )}
          <div class="p-8 md:p-12">
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map((tag) => (
                <span class="text-sm px-3 py-1.5 rounded-full bg-accent/20 text-primary border border-accent/20">{tag}</span>
              ))}
            </div>
            <h1 class="text-3xl md:text-5xl font-bold text-primary mb-6" transition:name={`${slug}-title`}>
              <span data-lang="es">{project.titleEs}</span>
              <span data-lang="en" hidden>{project.titleEn}</span>
            </h1>
            <p class="text-secondary text-lg md:text-xl leading-relaxed max-w-3xl mb-10">
              <span data-lang="es">{project.longDescEs}</span>
              <span data-lang="en" hidden>{project.longDescEn}</span>
            </p>

            <h2 class="text-xl font-bold text-primary mb-6 pt-8">
              <span data-lang="es">Características</span>
              <span data-lang="en" hidden>Features</span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
              {project.featuresEs.map((feat, i) => (
                <div class="flex items-start gap-3 p-4 rounded-xl bg-surface/50 border border-border/50">
                  <div class={`w-2 h-2 mt-2 rounded-full bg-gradient-to-b ${project.color} shrink-0`} />
                  <span class="text-secondary text-base">
                    <span data-lang="es">{feat}</span>
                    <span data-lang="en" hidden>{project.featuresEn[i]}</span>
                  </span>
                </div>
              ))}
            </div>

            {project.testimonialEs && (
              <div class="pt-8">
                <svg class="w-6 h-6 text-accent/40 mb-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                </svg>
                <p class="text-base text-primary italic leading-relaxed">
                  <span data-lang="es">{project.testimonialEs}</span>
                  <span data-lang="en" hidden>{project.testimonialEn}</span>
                </p>
              </div>
            )}
          </div>
        </div>
      </AnimatedSection>
    </div>
  </main>
</Layout>
